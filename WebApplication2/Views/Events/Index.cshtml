@model IEnumerable<EventEase.Models.Event>
@{
    ViewData["Title"] = "Events";
}

<h1>Events</h1>

<p>
    <a class="btn btn-primary" asp-action="Create">Create New</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Start</th>
            <th>End</th>
            <th>Venue</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.StartDate</td>
            <td>@item.EndDate</td>
            <td>@item.Venue?.Name</td>
            <td>
                <a class="btn btn-sm btn-secondary" asp-action="Details" asp-route-id="@item.EventId">Details</a>
                <a class="btn btn-sm btn-primary" asp-action="Edit" asp-route-id="@item.EventId">Edit</a>
                <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@item.EventId">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>
