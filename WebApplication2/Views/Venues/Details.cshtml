@model EventEase.Models.Venue
@{
    ViewData["Title"] = "Venue Details";
}

<h1>Venue Details</h1>

<div>
    <h4>@Model.Name</h4>
    <dl class="row">
        <dt class="col-sm-2">Location</dt>
        <dd class="col-sm-10">@Model.Location</dd>

        <dt class="col-sm-2">Capacity</dt>
        <dd class="col-sm-10">@Model.Capacity</dd>

        <dt class="col-sm-2">Available</dt>
        <dd class="col-sm-10">@(Model.IsAvailable ? "Yes" : "No")</dd>

        <dt class="col-sm-2">Image URL</dt>
        <dd class="col-sm-10">@Model.ImageUrl</dd>
    </dl>
</div>

<p>
    <a class="btn btn-secondary" asp-action="Index">Back to list</a>
    <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.VenueId">Edit</a>
</p>
