@model IEnumerable<EventEase.Models.Booking>
@{
    ViewData["Title"] = "Bookings";
}

<h1>Bookings</h1>

<p>
    <a class="btn btn-primary" asp-action="Create">Create New</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Reference</th>
            <th>Guest</th>
            <th>Event</th>
            <th>Venue</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.BookingRef</td>
            <td>@item.GuestName</td>
            <td>@item.Event?.Name</td>
            <td>@item.Venue?.Name</td>
            <td>@item.Status</td>
            <td>
                <a class="btn btn-sm btn-secondary" asp-action="Details" asp-route-id="@item.BookingId">Details</a>
                <a class="btn btn-sm btn-primary" asp-action="Edit" asp-route-id="@item.BookingId">Edit</a>
                <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@item.BookingId">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>
