@model EventEase.Models.Booking
@{
    ViewData["Title"] = "Booking Details";
}

<h1>Booking Details</h1>

<div>
    <h4>@Model.BookingRef</h4>
    <dl class="row">
        <dt class="col-sm-2">Guest</dt>
        <dd class="col-sm-10">@Model.GuestName</dd>

        <dt class="col-sm-2">Email</dt>
        <dd class="col-sm-10">@Model.GuestEmail</dd>

        <dt class="col-sm-2">Event</dt>
        <dd class="col-sm-10">@Model.Event?.Name</dd>

        <dt class="col-sm-2">Venue</dt>
        <dd class="col-sm-10">@Model.Venue?.Name</dd>

        <dt class="col-sm-2">Status</dt>
        <dd class="col-sm-10">@Model.Status</dd>
    </dl>
</div>

<p>
    <a class="btn btn-secondary" asp-action="Index">Back to list</a>
    <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.BookingId">Edit</a>
</p>
